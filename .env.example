# Copy to .env (already gitignored) and fill in real values there.
# Never commit .env. Never paste these values into a chat session.

# BingX VST (demo/paper) API credentials. Do not use a key with
# withdrawal or transfer permission — see CLAUDE.md's Non-negotiable
# Rules and Live Entry Criteria.
BINGX_API_KEY=
BINGX_API_SECRET=

# Defaults to the VST demo-trading host. Do not change to the
# production host (open-api.bingx.com) without going through
# CLAUDE.md's Live Entry Criteria and explicit human approval.
BINGX_BASE_URL=https://open-api-vst.bingx.com
